{
  "for": {
    "prefix": "for",
    "body": [
      "for (${2:size_t} ${1:i} = ${3:0}; $1 < ${4:len}; $1++) {",
      "\t$TM_SELECTED_TEXT$0",
      "}"
    ],
    "description": "Creates a 'for' loop"
  },
  "forr": {
    "prefix": "forr",
    "body": [
      "for (${2:size_t} ${1:i} = ${3:len}; $1 >= ${4:0}; $1--) {",
      "\t$TM_SELECTED_TEXT$0",
      "}"
    ],
    "description": "Creates a reverse 'for' loop"
  },

  "while": {
    "prefix": "while",
		"body": ["while ($1) {",
			"\t$TM_SELECTED_TEXT$0",
			"}"],
		"description": "Creates a while loop"
	},
	"Do...while loop": {
		"prefix": "dowhile",
		"body": [
			"do {",
			"\t$TM_SELECTED_TEXT$0",
			"} while($1);"],
		"description": "Creates a do...while loop"
	},

	"if": {
		"prefix": "if",
		"body": ["if($1) {", "\t$TM_SELECTED_TEXT$2", "}$0"],
		"description": "Creates an if statement"
	},
	"else": {
		"prefix": "else",
		"body": ["else {", "\t$TM_SELECTED_TEXT$1", "}$0"],
		"description": "Creates an else statement"
	},
	"elif": {
		"prefix": "else if",
		"body": ["else if($1) {", "\t$TM_SELECTED_TEXT$2", "}$0"],
		"description": "Creates an else-if statement"
	},

	"switch": {
		"prefix": "switch",
		"body": ["switch ($1) {",
			"$2",
			"default:",
			"\t$0",
			"\tbreak;",
			"}"],
		"description": "Creates a switch statement"
	},
	"Case statement": {
		"prefix": "case",
		"body": [
			"case $1:",
			"\t$2",
			"\tbreak;$0"
			],
		"description": "Creates a case branch"
	},

	"union": {
		"prefix": "union",
		"body": ["union $1 {", "\t$0", "};"],
		"description": "Creates a union"
	},
	"enum": {
		"prefix": "enum",
		"body": ["enum $1 {", "\t$0", "};"],
		"description": "Creates an enum"
	},

	"#ifdef": {
		"prefix": "#ifdef",
		"body": ["#ifdef ${1:DEBUG}", "$0", "#endif // $1"],
		"description": "Creates an #ifdef"
	},
	"#ifndef": {
		"prefix": "#ifndef",
		"body": ["#ifndef ${1:DEBUG}", "$0", "#endif // !$1"],
		"description": "Creates a #ifndef"
	},
	"#if": {
		"prefix": "#if",
		"body": ["#ifdef ${1:DEBUG}", "$0", "#endif // $1"],
		"description": "Creates an #if"
	},

	"Create function": {
		"prefix": "fun",
		"description": "Creates a function",
		"body": ["$1 ($2) {", "\t$0", "}"]
	},
	"#include \"\"": {
		"prefix": "incq",
		"body": ["#include \"$0.h\""],
		"description": "Creates a #include \" \""
	},
	"#def": {
		"prefix": "def",
		"body": ["#define $1 $0"],
		"description": "Creates a #define \" \""
	}
}
