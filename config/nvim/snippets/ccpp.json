{
  "for": {
    "prefix": "for",
    "body": [
      "for (${size_t} ${i} = ${1:0}; ${i} < ${2:length}; ${i}++) {",
      "\t${3:$TM_SELECTED_TEXT}",
      "}"
    ],
    "description": "Code snippet for 'for' loop"
  },
  "forr": {
    "prefix": "forr",
    "body": [
      "for (int ${i} = ${1:length} - 1; ${i} >= ${2:0}; ${i}--) {",
      "\t${3:$TM_SELECTED_TEXT}",
      "}"
    ],
    "description": "Code snippet for reverse 'for' loop"
  },

  "while": {
    "prefix": "while",
    "body": ["while ($1) {", "\t${2:$TM_SELECTED_TEXT}", "}$0"],
    "description": ""
  },
  "Do...while loop": {
    "prefix": "dowhile",
    "body": ["do {", "\t$1", "} while($2);"],
    "description": "Creates a do...while loop"
  },

  "if": {
    "prefix": "if",
    "body": ["if($1) {", "\t${2:$TM_SELECTED_TEXT}", "}$0"],
    "description": "Code snippet for if statement"
  },
  "else": {
    "prefix": "else",
    "body": ["else {", "\t${1:$TM_SELECTED_TEXT}", "}"],
    "description": "Code snippet for else statement"
  },
  "elif": {
    "prefix": "else if",
    "body": ["else if($1) {", "\t${2:TM_SELECTED_TEXT}", "}"],
    "description": "Code snippet for else-if statement"
  },

  "switch": {
    "prefix": "switch",
    "body": ["switch (${switch_on}) {", "default:", "\tbreak;$1", "}"],
    "description": "Code snippet for switch statement"
  },
  "case": {
    "prefix": "case",
    "body": ["case $1:", "\t$2", "\tbreak;$3"],
    "description": "Code snippet for case branch"
  },

	"union": {
		"prefix": "union",
		"body": ["union ${2} {", "\t$1", "};$0"],
		"description": "Code snippet for union"
	},
	"enum": {
		"prefix": "enum",
		"body": ["enum ${MyEnum} {", "\t$1", "};"],
		"description": "Code snippet for enum"
	},

	"#ifdef": {
		"prefix": "#ifdef",
		"body": ["#ifdef ${1:DEBUG}", "$0", "#endif // $1"],
		"description": "Code snippet for #ifdef"
	},
	"#ifndef": {
		"prefix": "#ifndef",
		"body": ["#ifndef ${1:DEBUG}", "$2", "#endif // !$1"],
		"description": "Code snippet for #ifndef"
	},
	"#if": {
		"prefix": "#if",
		"body": ["#ifdef ${1:0}", "$2", "#endif // $1"],
		"description": "Code snippet for #if"
	},

	"Create function": {
		"prefix": "fun",
		"description": "Creates a function",
		"body": ["${1}(${2}) {", "\t$0", "}"]
	},

  "#include \"\"": {
    "prefix": "inc",
    "body": ["#include \"$0\""],
    "description": "Code snippet for #include \" \""
  },
  "#include <>": {
    "prefix": "inct",
    "body": ["#include <$0>"],
    "description": "Code snippet for #include < >"
  },
  "#def": {
    "prefix": "def",
    "body": ["#define $1 $0 "],
    "description": "Code snippet for #define \" \""
  }
}
