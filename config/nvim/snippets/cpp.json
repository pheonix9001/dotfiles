{
  "foreach": {
    "prefix": "foreach",
    "body": ["for(auto $1 : $2) {", "\t$0", "}"],
    "description": "Creates a range-based for loop (c++11) statement"
  },

  "enum class": {
    "prefix": "eclass",
    "body": ["enum class ${MyClass} { };"],
    "description": "Code snippet for enum class (c++11)"
  },
  "class": {
    "prefix": "class",
    "body": [
      "class $1 {",
      "private:",
      "\t$0",
      "public:",
      "\t$1();",
      "\t~$1();",
      "};"
    ],
    "description": "Creates a class"
  },
  "namespace": {
    "prefix": "namespace",
    "body": ["namespace ${1:MyNamespace} {", "\t${0:$TM_SELECTED_TEXT}", "} /* namespace $1 */"]
  },

  "try": {
    "prefix": "try",
    "body": [
      "try {",
      "\t$1",
      "}",
      "catch (const std::exception&) {",
      "\t$0",
      "}"
    ],
    "description": "Creates a try-catch statement"
  },

  "std::cout": {
    "prefix": "cout",
    "body": ["std::cout << \"${0:/* message */}\" << std::endl;"],
    "description": "Creates a std::cout statement"
  },
  "std::cerr": {
    "prefix": "cerr",
    "body": ["std::cerr << \"${0:/* message */}\" << std::endl;"],
    "description": "Creates a std::cerr statement"
  },
	"#include <>": {
		"prefix": "inc",
		"body": ["#include <$0>"],
		"description": "Creates an #include <>"
	},

	"Contructer": {
		"prefix": "mem",
		"body": [
			"$1::$1($2) {",
			"\t$0",
			"}"
			],
		"description": "Creates a contructer"
	},

	"Standard Starter Template": {
		"prefix": "sst",
		"body": [
			"#include <iostream>",
			"",
			"int main (int argc, char *argv[]) {",
			"\t${0:std::cout << \"Hello world\" << std::endl;}",
			"\treturn 0;",
			"}"
		],
		"description": "A standard starter template for a C program"
	}
}
